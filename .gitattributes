# Auto-detect text files and use LF line endings
* text=auto eol=lf

# Python and plain-text files use LF line endings
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.pseudo text eol=lf
*.csv text eol=lf

# Scripts use LF line endings
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.command text eol=lf
*.ps1 text eol=lf
*.bat text eol=lf
*.cmd text eol=lf

# Treat common binary files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
*.zip binary
