# WARNING: Do NOT modify this file.
# If there is a problem with it, submit a GitHub issue or pull request to fix it.

# Auto-detect text files and normalize line endings in the repo
* text=auto

# Python and plain-text files should use LF line endings
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.pseudo text eol=lf
*.csv text eol=lf

# Linux/macOS scripts should use LF line endings
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.command text eol=lf

# Windows scripts should use CRLF line endings
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat common binary files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
*.zip binary
